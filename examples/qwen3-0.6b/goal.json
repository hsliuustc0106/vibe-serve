{
  "schema_version": 1,
  "name": "qwen3-0.6b-completions-baseline",
  "target": {
    "model": "Qwen/Qwen3-0.6B",
    "tokenizer": "Qwen/Qwen3-0.6B",
    "modality": "text_generation",
    "workload": "single-batch random completion baseline",
    "hardware": {
      "device_type": "cuda",
      "max_devices": 1,
      "dtype": "bfloat16"
    }
  },
  "interface": {
    "base_url_env": "VIBESERVE_URL",
    "required_endpoints": [
      {
        "method": "GET",
        "path": "/health"
      },
      {
        "method": "GET",
        "path": "/v1/models"
      },
      {
        "method": "POST",
        "path": "/v1/completions"
      }
    ],
    "streaming_required": false,
    "default_model_name": "Qwen/Qwen3-0.6B"
  },
  "correctness": {
    "checker": "accuracy_checker/checker.py",
    "required_exit_code": 0,
    "default_samples": 3,
    "minimum_similarity": 0.0,
    "reject_on_transport_error": true,
    "reject_on_empty_output": true
  },
  "benchmark": {
    "script": "benchmark/benchmark.py",
    "primary_metric": "tokens_per_sec",
    "higher_is_better": true,
    "default_samples": 64,
    "warmup": 1,
    "benchmark_matrix": [
      {
        "name": "baseline_sweep",
        "concurrency": 32,
        "num_samples": 64
      }
    ]
  },
  "baseline": {
    "engine": "vllm",
    "description": "Single-device vLLM baseline on random vLLM bench workload (512/128, 32x64).",
    "metrics": {
      "tokens_per_sec": null,
      "success_rate": 1.0
    }
  },
  "acceptance": {
    "checker_must_pass": true,
    "success_rate": 1.0,
    "record_primary_metric": true,
    "compare_against_baseline": true,
    "package_deployable_engine": true
  },
  "forbidden_shortcuts": [
    "Do not return hard-coded or cached completion payloads.",
    "Do not skip model execution in the benchmark path.",
    "Do not edit benchmark/accuracy/reference artifacts inside a candidate workspace."
  ],
  "staged_validation": [
    "server_startup",
    "health_check",
    "checker_smoke",
    "benchmark_matrix"
  ]
}

